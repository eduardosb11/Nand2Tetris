CHIP DMux4Way {
    IN in, sel[2];
    OUT a, b, c, d;

    PARTS:
    Not(in=sel[0], out=notsel0);
    Not(in=sel[1], out=notsel1);

    And(a=notsel0, b=notsel1, out=w1);
    And(a=sel[0], b= notsel1, out=w2);
    And(a=notsel0, b=sel[1], out=w3);
    And(a=sel[0], b=sel[1], out=w4);

    And(a=w1, b=in, out=a);
    And(a=w2, b=in, out=b);
    And(a=w3, b=in, out=c);
    And(a=w4, b=in, out=d);
}
